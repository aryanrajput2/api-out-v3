{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/main.py"
    },
    {
      "source": "/ui/(.*)",
      "destination": "/hotel-ui/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/main.py"
    }
  ]
}
